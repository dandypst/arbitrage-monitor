# Get from https://dune.com/settings/api
DUNE_API_KEY=

# The ID of a saved Dune query that returns columns:
# chain, pair, dex, price, updated_at
# See README.md for a starter SQL query.
DUNE_SAME_CHAIN_QUERY_ID=

# --- Telegram alerts ---
# Create a bot via @BotFather on Telegram, get the token it gives you.
TELEGRAM_BOT_TOKEN=
# Your numeric chat ID (see README for how to find it).
TELEGRAM_CHAT_ID=
# Minimum gap % to trigger a Telegram alert (separate from the dashboard's
# display threshold in lib/tokens.ts — alerts are usually set higher).
ALERT_MIN_GAP_PCT=1

# Random string (16+ chars) used to authorize calls to /api/alert-check,
# so random people on the internet can't trigger your bot / burn your Dune credits.
CRON_SECRET=
